version: '3.8'
services:
  forgejo:
    image: gitea/gitea:latest
    container_name: forgejo
    restart: unless-stopped
    ports:
      - "3005:3000"
      - "2222:22"
    environment:
      - USER_UID=1000
      - USER_GID=1000
      - FORGEJO__database__DB_TYPE=postgres
      - FORGEJO__database__HOST=forgejo_db:5432
      - FORGEJO__database__NAME=${DB_NAME}
      - FORGEJO__database__USER=${DB_USERNAME}
      - FORGEJO__database__PASSWD=${DB_PASSWORD}
      - TZ=${TZ}
      - GITEA__server__ROOT_URL=${ROOT_URL}
    volumes:
      - ./data:/data
    depends_on:
      - forgejo_db
    networks:
      - security-net

  forgejo_db:
    image: postgres:14-alpine
    container_name: forgejo_db
    restart: unless-stopped
    environment:
      - POSTGRES_USER=${DB_USERNAME}
      - POSTGRES_PASSWORD=${DB_PASSWORD}
      - POSTGRES_DB=${DB_NAME}
    volumes:
      - ./postgres:/var/lib/postgresql/data
    networks:
      - security-net

networks:
  security-net:
    external: true
    name: security-net
